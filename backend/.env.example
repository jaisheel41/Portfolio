SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Optional: comma-separated. On Render, hostname from RENDER_EXTERNAL_URL is added automatically.
# ALLOWED_HOSTS=localhost,127.0.0.1,your-service.onrender.com

# Supabase PostgreSQL — Project Settings → Database → Connect
#
# Direct (port 5432): db.PROJECT_REF.supabase.co — may resolve to IPv6 only.
# Render / some hosts are IPv4-only → use Transaction pooler below instead.
#
# Transaction pooler (port 6543): IPv4-friendly. Dashboard shows host like
# aws-0-REGION.pooler.supabase.com and user postgres.PROJECT_REF
# Set DB_USE_SUPABASE_POOLER=True (or DB_PORT=6543) when using the pooler.
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=aws-0-REGION.pooler.supabase.com
DB_PORT=6543
DB_USE_SUPABASE_POOLER=True
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET_NAME=
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_REGION=
# Public read URL (bucket → Public). NOT the S3 API URL (*.storage.supabase.co/.../s3/...).
SUPABASE_STORAGE_PUBLIC_BASE=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/YOUR_BUCKET
SUPABASE_STORAGE_MEDIA_URL=