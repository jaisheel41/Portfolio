SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Optional: comma-separated. On Render, hostname from RENDER_EXTERNAL_URL is added automatically.
# ALLOWED_HOSTS=localhost,127.0.0.1,your-service.onrender.com

# Supabase PostgreSQL (Project Settings → Database → connection parameters)
# Use the direct connection (port 5432) for migrations.
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET_NAME=
SUPABASE_S3_ENDPOINT_URL=
SUPABASE_S3_REGION=
SUPABASE_STORAGE_PUBLIC_BASE=
SUPABASE_STORAGE_MEDIA_URL=